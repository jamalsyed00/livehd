// Benchmark fixture: constant-folding workload for upass vs cprop comparison.
//
// 10 constant multiplications — foldable by fold_mult_const / cprop
m0 = 3  * 4     // → 12
m1 = 2  * 5     // → 10
m2 = 6  * 7     // → 42
m3 = 8  * 9     // → 72
m4 = 10 * 10    // → 100
m5 = 11 * 11    // → 121
m6 = 4  * 25    // → 100
m7 = 3  * 33    // → 99
m8 = 7  * 8     // → 56
m9 = 16 * 4     // → 64

// 10 constant additions — foldable by fold_sum_const / cprop
a0 = 3  + 4     // → 7
a1 = 10 + 20    // → 30
a2 = 15 + 25    // → 40
a3 = 100 + 200  // → 300
a4 = 7  + 13    // → 20
a5 = 42 + 58    // → 100
a6 = 1  + 1     // → 2
a7 = 99 + 1     // → 100
a8 = 50 + 50    // → 100
a9 = 0  + 1     // → 1
